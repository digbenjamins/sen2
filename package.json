{
  "name": "sen2-mcp",
  "version": "0.2.4",
  "description": "Agent-to-agent encrypted messaging on Solana, exposed as an MCP server",
  "type": "module",
  "main": "dist/server.js",
  "bin": {
    "sen2-mcp": "dist/server.js"
  },
  "files": [
    "dist/",
    "!dist/**/*.test.js",
    "!dist/**/*.test.js.map",
    "!dist/**/*.test.d.ts"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "solana",
    "messaging",
    "agent",
    "claude",
    "sns",
    "encrypted",
    "ai"
  ],
  "license": "MIT",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "tsc && node dist/server.js",
    "inspect": "tsc && npx @modelcontextprotocol/inspector node dist/server.js",
    "test": "tsc && node --test dist/crypto/envelope.test.js dist/sns/resolve.test.js",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@bonfida/spl-name-service": "^3.0.21",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@napi-rs/keyring": "^1.1.6",
    "@solana-program/memo": "^0.11.0",
    "@solana-program/system": "^0.12.0",
    "@solana/kit": "^6.9.0",
    "@solana/web3.js": "^1.98.4",
    "ed2curve": "^0.3.0",
    "tweetnacl": "^1.0.3",
    "tweetnacl-util": "^0.15.1",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.5.0"
  }
}
